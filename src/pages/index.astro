---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Stack from '../components/Stack.astro';
import Contact from '../components/Contact.astro';
---

<!doctype html>
<html lang="en" data-theme="ddhq">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DDHQ — We make the web simple and clear</title>
    <meta name="description" content="DDHQ — A development team. Websites, web apps, services, and AI solutions on a modern stack. Reach us at m@ddhq.site" />

    <!-- Open Graph -->
    <meta property="og:title" content="DDHQ — We make the web simple and clear" />
    <meta property="og:description" content="We build websites, web apps, services, and chatbots. No marketing fluff." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ddhq.site" />
    <meta property="og:locale" content="en_US" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%234F46E5'/><text x='16' y='22' text-anchor='middle' fill='white' font-family='system-ui' font-weight='bold' font-size='16'>D</text></svg>" />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content antialiased">
    <Header />
    <main>
      <Hero />
      <Services />
      <Stack />
      <Contact />
    </main>
  </body>
</html>

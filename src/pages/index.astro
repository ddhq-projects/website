---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ddhq website</title>
  </head>
  <body class="min-h-screen bg-base-200">
    <main class="hero min-h-screen">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <span class="badge badge-primary badge-lg">Astro + Tailwind + DaisyUI</span>
          <h1 class="mt-6 text-5xl font-bold">website</h1>
          <p class="py-6 text-base-content/80">
            A minimal AstroJS website scaffolded with Tailwind CSS utilities and DaisyUI
            components.
          </p>
          <div class="flex justify-center gap-3">
            <a class="btn btn-primary" href="https://astro.build/">Astro</a>
            <a class="btn btn-outline" href="https://daisyui.com/">DaisyUI</a>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>

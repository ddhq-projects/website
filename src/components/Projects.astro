---
interface Project {
  title: string;
  description: string;
  href?: string;
  status: 'live' | 'progress';
}

const projects: Project[] = [
  {
    title: 'DDHQ Site',
    description: 'Сайт команды — Astro + Tailwind CSS + DaisyUI. Одностраничник, быстрая загрузка.',
    href: 'https://ddhq.ru',
    status: 'live',
  },
  {
    title: 'wpcraft.ru',
    description: 'Проект на WordPress — разработка плагинов и документация для wpcraft.',
    href: 'https://wpcraft.ru',
    status: 'live',
  },
  {
    title: 'DDHQ Tools',
    description: 'Внутренние инструменты и библиотеки для разработки. В процессе.',
    status: 'progress',
  },
  {
    title: 'Новый AI-проект',
    description: 'AI-инструмент для автоматизации контента. Ранняя стадия.',
    status: 'progress',
  },
];
---

<section id="projects" class="bg-base-100 py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center max-w-xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-base-content">Проекты</h2>
      <p class="mt-4 text-base-content/60 text-lg">Что мы уже сделали и над чем работаем сейчас</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div class="card bg-base-200 border border-base-300 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="card-body">
            <div class="flex items-start justify-between">
              <h3 class="card-title text-lg font-semibold">
                {project.href ? (
                  <a href={project.href} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                    {project.title}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline ml-1 -mt-0.5 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                ) : (
                  project.title
                )}
              </h3>
              <span class={`badge badge-sm ${project.status === 'live' ? 'badge-success' : 'badge-warning'}`}>
                {project.status === 'live' ? 'Live' : 'В работе'}
              </span>
            </div>
            <p class="text-base-content/60 text-sm mt-1">{project.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
